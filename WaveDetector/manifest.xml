<?xml version="1.0" encoding="UTF-8"?>
<iq:manifest xmlns:iq="http://www.garmin.com/xml/connectiq" version="3">
    <iq:application
        id="b2c3d4e5-f6a7-8901-bcde-f12345678901"
        type="watch-app"
        name="@Strings.AppName"
        entry="WaveDetectorApp"
        launcherIcon="@Drawables.LauncherIcon"
        minSdkVersion="3.2.0">

        <!-- Companion app to UtilityFace (see ../UtilityFace/MEMORY.md next
             step 6): live accelerometer-based wave/motion detection. Split
             out as a separate App (not a watch face) because watch faces
             can't hold a continuous high-rate sensor listener the way an
             app context can. See HeadingServiceDelegate.mc in UtilityFace
             for what happens when you try to get live sensor data into a
             watchface without one. -->
        <iq:products>
            <iq:product id="instinct2" />
        </iq:products>

        <iq:permissions>
            <iq:uses-permission id="Sensor" />
        </iq:permissions>

        <iq:languages>
            <iq:language>eng</iq:language>
        </iq:languages>

        <iq:barrels />
    </iq:application>
</iq:manifest>
